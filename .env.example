# vLLM server configuration
VLLM_BASE_URL=http://localhost:8000/v1
# Recommended: openai/gpt-oss-20b (MoE 20B, ~2.2GB active VRAM, 61 tok/s, score 93)
#   vllm serve openai/gpt-oss-20b --port 8000 --dtype auto
# Fallback (confirmed 4GB fit): Qwen/Qwen2.5-3B-Instruct
#   vllm serve Qwen/Qwen2.5-3B-Instruct --port 8000
# If vLLM OOMs, use llama-server (same API, no config change needed):
#   llama-server -m gpt-oss-20b-Q4_K_M.gguf --port 8000 -ngl 99
VLLM_MODEL=openai/gpt-oss-20b

# Database
DB_PATH=data/jobs.db

# API server
API_HOST=0.0.0.0
API_PORT=8080

# Optional: Naukri credentials (for Phase 1b)
NAUKRI_EMAIL=
NAUKRI_PASSWORD=

# Optional: scraping settings
SCRAPE_CONCURRENCY=3
REQUEST_TIMEOUT=30
